# ─────────────────────────────────────────────────────────────────────────────
# Podcast Cutter AI — Environment Configuration
# Copy this file to .env and adjust the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Whisper (faster-whisper) ─────────────────────────────────────────────────
# Available models: tiny, base, small, medium, large-v2, large-v3
# Larger models = better accuracy, slower transcription, more RAM usage
# Recommended for CPU-only: base or small
WHISPER_MODEL=base

# Device to run Whisper on: "cpu" or "cuda"
WHISPER_DEVICE=cpu

# Quantization type. Options: int8, int8_float16, int16, float16, float32
# int8 is fastest on CPU with minimal quality loss
WHISPER_COMPUTE_TYPE=int8

# Force a specific language (e.g. "pt", "en"). Leave empty for auto-detect.
WHISPER_LANGUAGE=

# ── Video ────────────────────────────────────────────────────────────────────
# Maximum video resolution in pixels (height). Common values: 360, 480, 720, 1080
VIDEO_QUALITY=720

# ── yt-dlp ────────────────────────────────────────────────────────────────────
# Path to a cookies.txt file exported from your browser (recommended).
# Export from Brave/Chrome: install "Get cookies.txt LOCALLY" → youtube.com → Export.
YTDLP_COOKIES_FILE=cookies.txt

# Direct browser cookie extraction — broken on Windows with Chrome/Brave 127+.
# Only reliable with Firefox. Leave empty to disable.
YTDLP_COOKIE_BROWSER=

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Base URL of your running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for clip detection. Must be pulled via: ollama pull <model>
# Recommended: llama3.2 (128k context) or gemma3:12b
OLLAMA_MODEL=llama3.2

# Inference temperature (0.0 = deterministic, 1.0 = creative)
OLLAMA_TEMPERATURE=0.3

# Timeout in seconds per LLM call — prevents zombie requests
OLLAMA_TIMEOUT_SECONDS=120

# ── Pipeline ─────────────────────────────────────────────────────────────────
# Minimum clip duration in seconds
MIN_CLIP_DURATION=60

# Maximum clip duration in seconds
MAX_CLIP_DURATION=120

# Maximum number of viral clips to detect per video
MAX_CLIPS=10

# ── Storage ──────────────────────────────────────────────────────────────────
# Base directory for all generated artifacts
STORAGE_DIR=storage

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directory for log files
LOG_DIR=logs
