# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── uv ───────────────────────────────────────────────────────────────────────
.uv/

# ── Environment variables ─────────────────────────────────────────────────────
.env

# ── YouTube cookies (contains active session — never commit) ──────────────────
cookies.txt

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/*.log
logs/**/*.log

# ── Storage artifacts (large files — never commit) ───────────────────────────
storage/audio/*
storage/transcripts/*
storage/videos/*
storage/jobs/*
storage/cuts/*
storage/subtitles/*
storage/rendered/*

# Preserve directory structure via .gitkeep files
!storage/audio/.gitkeep
!storage/transcripts/.gitkeep
!storage/videos/.gitkeep
!storage/jobs/.gitkeep
!storage/cuts/.gitkeep
!storage/subtitles/.gitkeep
!storage/rendered/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
